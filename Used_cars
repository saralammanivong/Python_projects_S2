# CELLULE 2.8 : SYNTHÈSE POUR LE FEATURE ENGINEERING
####################################################################################################
from scipy.stats import normaltest

# 1. Gestion des catégories rares : groupement des catégories > 5% sous "Other"
if has_make:
    print("\n> Gestion des marques rares :")
    freq = df["make_name"].value_counts(normalize=True)
    rare_labels = freq[freq < 0.05].index
    df["make_name_grouped"] = df["make_name"].replace(rare_labels, "Other")
    print(f"Nombre de marques regroupées en 'Other' : {len(rare_labels)}")

# 2. Discrétisation / Binning : Conversion de l'âge (variable continue) en catégories pour simplifier les relations
if has_year:
    df['car_age'] = 2026 - df['year']
    # Création de 3 classes : Récent, Intermédiaire, Ancien
    df["age_group"] = pd.cut(df["car_age"], bins=3, labels=["Récent", "Intermédiaire", "Ancien"])
    print("\n> Discrétisation de l'âge terminée.")
    print(df["age_group"].value_counts())

# 3. Test de normalité statistique
if has_price:
    # On prend un échantillon car le test est sensible aux grands datasets
    sample_price = df['price'].dropna().sample(min(1000, len(df)))
    stat, p = normaltest(sample_price)
    print(f"\n> Test de normalité (D'Agostino) sur le prix : p-value = {p:.5f}")
    if p < 0.05:
        print("Interprétation : La distribution n'est pas normale. Une transformation log est recommandée.")

# 4. Création d'indicateurs d'interaction
if has_hp and has_price:
    # Exemple du cours : combiner des variables pour capturer des interactions
    df["hp_price_ratio"] = df["horsepower"] / (df["price"] + 1)
    
#%% ################################################################################################
# CELLULE 3 : PREPROCESSING ET FEATURE ENGINEERING
####################################################################################################
from sklearn.preprocessing import StandardScaler, MinMaxScaler
from sklearn.impute import SimpleImputer

print("*** DÉMARRAGE DU PREPROCESSING FINAL ***")

# 1. Gestion des valeurs manquantes
# On traite les données manquantes avant transformation.
# On impute par la médiane pour les numériques (plus robuste aux outliers détectés en EDA)
imputer_num = SimpleImputer(strategy="median")
cols_to_impute = ['horsepower', 'mileage', 'daysonmarket']
available_cols = [c for c in cols_to_impute if c in df.columns]
df[available_cols] = imputer_num.fit_transform(df[available_cols])

# 2. Créations d'indicateurs
# On combine les variables pour capturer une information plus significative
if has_mileage and has_year:
    # Calcul de l'âge si pas encore fait
    if 'car_age' not in df.columns:
        df['car_age'] = 2026 - df['year']
    # Intensité d'usage (kilométrage moyen par an)
    df['mileage_per_year'] = df['mileage'] / (df['car_age'] + 1)
    print("> Indicateur 'mileage_per_year' créé.")

# 3. Gestion des catégories rares
# On regroupe sous "Other" les labels représentant moins de 5% du dataset
for col in ['fuel_type', 'transmission']:
    if col in df.columns:
        freq = df[col].value_counts(normalize=True)
        rare_labels = freq[freq < 0.05].index
        df[col] = df[col].replace(rare_labels, "Other")
print("> Gestion des catégories rares terminée.")

# 4. Transformation de features via le logarithme afin de rendre les distributions plus proches de la normale
if has_price:
    df["price_log"] = np.log1p(df["price"])
    print("> Transformation logarithmique du prix effectuée.")

# 5. Standardisation pour harmoniser les échelles (Moyenne = 0, Écart-type = 1)
scaler = StandardScaler()
cols_to_scale = ['mileage', 'horsepower', 'car_age']
available_scale = [c for c in cols_to_scale if c in df.columns]
df[available_scale] = scaler.fit_transform(df[available_scale])
print(f"> Standardisation effectuée sur : {available_scale}")

# 5 BIS. Normalisation Min-Max
scaler_minmax = MinMaxScaler()
df[available_scale] = scaler_minmax.fit_transform(df[available_scale])
print(f"> Normalisation Min-Max effectuée sur : {available_scale}")

# 6. Encodage One-Hot pour les variables catégorielles sans ordre inhérent

cols_to_encode = ['fuel_type', 'age_group', 'make_name_grouped']
available_encode = [c for c in cols_to_encode if c in df.columns]
df = pd.get_dummies(df, columns=available_encode, drop_first=True)
print(f"> Encodage One-Hot effectué sur : {available_encode}")

print(f"Nombre final de colonnes (Features) : {df.shape[1]}")
