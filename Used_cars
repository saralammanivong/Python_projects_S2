# Technique Quantitative : TRIMEAN (Trimoyenne sur le prix)
def calculate_trimean(series):
    q1 = series.quantile(0.25)
    q2 = series.quantile(0.50)
    q3 = series.quantile(0.75)
    return (q1 + 2*q2 + q3) / 4

